# =============================================================================
#  Mathieu&Co Studio — Template de variables d'environnement
#  ✅ Ce fichier EST commité dans git (pas de vraies valeurs ici).
#  → Copier en .env.local et remplir les vraies valeurs.
# =============================================================================


# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development


# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=


# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard → Développeurs → Clés API (utiliser pk_test_ / sk_test_ en dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_


# ─── Email — Resend ──────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_
EMAIL_FROM=Mathieu&Co Studio <noreply@mathieu-co.studio>
EMAIL_REPLY_TO=contact@mathieu-co.studio


# ─── Stockage — Supabase Storage ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=media


# ─── Analytics ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-


# ─── Sécurité ────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
CRON_SECRET=
API_SECRET_KEY=


# ─── Paiements locaux — FedaPay (optionnel) ──────────────────────────────────
# FEDAPAY_SECRET_KEY=sk_sandbox_
# NEXT_PUBLIC_FEDAPAY_PUBLIC_KEY=pk_sandbox_


# ─── SMS — Twilio (optionnel) ─────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+229
