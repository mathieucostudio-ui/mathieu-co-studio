# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — les vraies valeurs ne sont jamais commitées
.env*
# sauf le template de documentation (pas de vraies valeurs)
!.env.example

# vercel
.vercel

# Claude Code local settings (permissions, etc.)
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
